# --- Database (required) ---
# Postgres connection string. Must include the postgresql:// scheme for Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/blipko"

# --- Server (optional) ---
# PORT defaults to 4000; NODE_ENV defaults to "development".
PORT=4000
NODE_ENV=development

# --- AI parsing (required) ---
# Both keys are required at boot — the bot exits if either is blank.
GEMINI_API_KEY="your_gemini_api_key"
GEMINI_MODEL="gemini-2.0-flash"
OPENAI_API_KEY="your_openai_api_key"

# --- Voice transcription (optional) ---
# If blank, voice messages are disabled and users are asked to type instead.
SARVAM_API_KEY=""

# --- Telegram (required) ---
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN="your_bot_token_from_botfather"
# Shared secret Telegram sends back on each webhook call (X-Telegram-Bot-Api-Secret-Token).
TELEGRAM_WEBHOOK_SECRET="required_secret_for_webhook_verification"
