# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET="your_auth_secret_here"

# Google OAuth — create at console.cloud.google.com
AUTH_GOOGLE_ID="your_google_oauth_client_id"
AUTH_GOOGLE_SECRET="your_google_oauth_client_secret"

# Required in production (your deployed URL, no trailing slash)
AUTH_URL="https://yourdomain.com"

# Prisma Accelerate — get from prisma.io/data-platform
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# Resend — get from resend.com (used for welcome email on sign-in)
RESEND_API_KEY="re_your_resend_api_key"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username_without_@"
